#!/bin/bash

# Check if zoxide is installed
if ! command -v zoxide >/dev/null 2>&1; then
  echo "Error: zoxide is not installed or not found in PATH."
  exit 1
fi

# Check if code (Visual Studio Code) is installed
if ! command -v code >/dev/null 2>&1; then
  echo "Error: code is not installed or not found in PATH."
  exit 1
fi

# Check if the argument provided is a valid relative path or a zoxide query
if [ -e "$*" ]; then
  code "$*"
else
  code "$(zoxide query "$*")"
fi